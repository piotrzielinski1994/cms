{
  "name": "cms",
  "version": "1.0.0",
  "description": "CMS scaffold",
  "author": {
    "name": "Piotr Zieliński"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "build:analyze": "ANALYZE=true cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" next dev",
    "start:db": "docker compose up -d --quiet-pull",
    "start:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && npm run build && next start",
    "upgrade": "npm-check-updates -u && npm update",
    "upgrade:except": "npm-check-updates -u -x tailwindcss && npm update",
    "test": "NODE_ENV=test next typegen && tsc --noEmit && vitest run --reporter=verbose --coverage",
    "test:watch": "NODE_ENV=test vitest watch --reporter=verbose -u",
    "ts": "tsc --noEmit",
    "ts:watch": "tsc --noEmit --watch",
    "storybook:build": "STORYBOOK_LOGLEVEL=debug storybook build -c ./src/config/storybook -o .storybook",
    "storybook": "storybook dev -c ./src/config/storybook -p 3001",
    "storybook:prod": "serve .storybook",
    "thumbnails": "tsx --env-file=.env ./src/thumbnails.ts",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation npm --ignore-workspace install",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm npm-lock.yaml && npm --ignore-workspace install",
    "serve": "cross-env NODE_OPTIONS=--no-deprecation next start"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@next/third-parties": "^16.2.11",
    "@payloadcms/admin-bar": "latest",
    "@payloadcms/db-mongodb": "latest",
    "@payloadcms/live-preview-react": "latest",
    "@payloadcms/next": "latest",
    "@payloadcms/payload-cloud": "latest",
    "@payloadcms/plugin-ecommerce": "^3.86.0",
    "@payloadcms/plugin-form-builder": "latest",
    "@payloadcms/plugin-nested-docs": "latest",
    "@payloadcms/plugin-redirects": "latest",
    "@payloadcms/plugin-search": "latest",
    "@payloadcms/plugin-seo": "latest",
    "@payloadcms/richtext-lexical": "latest",
    "@payloadcms/storage-vercel-blob": "^3.86.0",
    "@payloadcms/ui": "latest",
    "@radix-ui/react-checkbox": "^1.3.9",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.13",
    "@radix-ui/react-select": "^2.3.5",
    "@radix-ui/react-slot": "^1.3.1",
    "@sentry/nextjs": "^10.67.0",
    "@svgr/webpack": "^8.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "graphql": "^16.14.0",
    "lucide-react": "^1.26.0",
    "next": "^16.2.11",
    "next-intl": "^4.13.4",
    "next-sitemap": "^4.2.3",
    "payload": "latest",
    "prism-react-renderer": "^2.4.1",
    "radix-ui": "^1.6.5",
    "ramda": "^0.32.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-hook-form": "^7.82.0",
    "responsive-loader": "^3.1.2",
    "sharp": "^0.35.3",
    "slugify": "^1.6.9",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript-cookie": "^1.0.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@next/bundle-analyzer": "^16.2.11",
    "@storybook/addon-themes": "^10.5.3",
    "@storybook/nextjs": "^10.5.3",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/escape-html": "^1.0.4",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "26.1.1",
    "@types/ramda": "^0.32.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "@vitejs/plugin-react": "^6.0.4",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "copyfiles": "^2.4.1",
    "jsdom": "^29.1.1",
    "npm-check-updates": "^22.2.9",
    "postcss": "^8.5.22",
    "puppeteer": "^25.3.0",
    "serve": "^14.2.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "tw-colors": "^3.3.2",
    "typescript": "7.0.2",
    "vitest": "^4.1.10",
    "vitest-axe": "^0.1.0"
  },
  "engines": {
    "node": "24.x"
  }
}
