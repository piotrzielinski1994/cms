{
  "$schema": "https://biomejs.dev/schemas/2.5.5/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["**", "!.next", "!.storybook", "!next-env.d.ts", "!src/payload/payload.types.ts"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn",
        "noEmptyInterface": "warn",
        "noArrayIndexKey": "warn",
        "noShadowRestrictedNames": "warn",
        "noImplicitAnyLet": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn"
      },
      "complexity": {
        "noUselessFragments": "warn",
        "noBannedTypes": "warn"
      },
      "correctness": {
        "noUnsafeOptionalChaining": "warn",
        "noVoidTypeReturn": "warn",
        "noChildrenProp": "warn",
        "noUnusedVariables": {
          "level": "warn",
          "options": {}
        }
      },
      "a11y": {
        "noSvgWithoutTitle": "warn",
        "noLabelWithoutControl": "warn",
        "useHtmlLang": "warn",
        "useSemanticElements": "warn",
        "noStaticElementInteractions": "warn"
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
