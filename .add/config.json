{
  "$schema": "https://github.com/MountainUnicorn/add/config.schema.json",
  "version": "0.5.0",
  "project": {
    "name": "cms",
    "description": "Personal CMS / e-commerce on Next.js + Payload",
    "created": "2026-05-24",
    "author": "Piotr Zieliński"
  },
  "maturity": {
    "level": "alpha",
    "promoted_from": null,
    "promoted_date": null,
    "next_promotion_criteria": "Specs for all user-facing features, 50%+ coverage, PR workflow with reviews, branch protection, TDD evidence across multiple cycles"
  },
  "architecture": {
    "languages": [
      {
        "name": "TypeScript",
        "version": "5.x",
        "role": "fullstack"
      }
    ],
    "backend": {
      "framework": "Payload CMS + Next.js",
      "version": "16.2.6",
      "runtime": "Node 22.x"
    },
    "frontend": {
      "framework": "Next.js (App Router) + React",
      "version": "16.2.6",
      "bundler": "turbopack"
    },
    "database": {
      "type": "MongoDB",
      "version": "latest (docker-compose)"
    },
    "containerized": true,
    "container_strategy": "docker-compose",
    "suggested_by_claude": false
  },
  "infrastructure": {
    "git_host": "github",
    "git_remote": "git@github.com:piotrzielinski1994/cms.git",
    "cloud_provider": "none",
    "cloud_services": [],
    "cicd": {
      "platform": "github-actions",
      "scaffolded_by_add": false,
      "pipeline_file": ".github/workflows/{on-dependabot.yaml,on-merge.yaml,on-release.yaml}"
    },
    "infrastructure_as_code": "none"
  },
  "environments": {
    "tier": 1,
    "local": {
      "run": "npm start",
      "test": "npm test",
      "e2e": null,
      "url": "http://localhost:3000"
    },
    "dev": {
      "deploy_trigger": null,
      "url": null,
      "verify": []
    },
    "staging": {
      "deploy_trigger": null,
      "url": null,
      "verify": []
    },
    "production": {
      "deploy_trigger": null,
      "verify": [],
      "url": null,
      "requires_approval": true
    }
  },
  "quality": {
    "mode": "standard",
    "coverage_threshold": 80,
    "type_check_blocking": true,
    "e2e_required": false,
    "screenshot_protocol": true,
    "lint": {
      "backend": "npm run lint",
      "frontend": "npm run lint"
    },
    "typecheck": {
      "backend": "npm run ts",
      "frontend": "npm run ts"
    },
    "test": {
      "unit": "npm test",
      "integration": "npm test",
      "e2e": null
    }
  },
  "collaboration": {
    "autonomy_level": "balanced",
    "team_size": "solo",
    "commit_review_gate": false,
    "pr_review_gate": true,
    "deploy_approval_required": true
  },
  "source_control": {
    "branching": "feature-branches",
    "default_branch": "main",
    "commit_convention": "conventional",
    "pr_template": true,
    "protected_branches": ["main"]
  },
  "branding": {
    "accentColor": "#b00149",
    "presetName": "raspberry",
    "palette": {
      "accent": "#b00149",
      "accentLight": "#d4326d",
      "accentDark": "#8a0038",
      "accentMuted": "#c4607a",
      "accentGlow": "rgba(176,1,73,0.4)",
      "gradientStart": "#b00149",
      "gradientMid": "#d4326d",
      "gradientEnd": "#ff6b9d",
      "success": "#22c55e",
      "warning": "#eab308",
      "info": "#0ea5e9"
    },
    "fonts": null,
    "tone": null,
    "logoPath": null,
    "styleGuideSource": null
  },
  "imageGeneration": {
    "enabled": false,
    "tool": null,
    "plugin": null,
    "nudged": false,
    "lastDetected": null
  },
  "changelog": {
    "lastProcessedCommit": null,
    "lastVersionTag": null
  },
  "learnings": {
    "active_cap": 15,
    "archival_days": 90,
    "archival_max_severity": "medium"
  },
  "planning": {
    "current_milestone": null,
    "current_cycle": null,
    "wip_limit": 3,
    "parallel_agents": 1,
    "cycle_history": []
  }
}
